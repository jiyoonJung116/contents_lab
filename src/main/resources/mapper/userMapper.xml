<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jjy.contents_lab.mapper.UserMapper">
    <resultMap id="UserMap" type="com.jjy.contents_lab.dto.UserDto">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="userName" column="user_name"/>
        <result property="nickname" column="nickname"/>
        <result property="profileImageUrl" column="profile_image_url"/>
        <result property="planType" column="plan_type"/>
        <result property="interestContent" column="interest_content"/>
        <result property="storageLimit" column="storage_limit"/>
        <result property="adminYn" column="admin_yn"/>
        <result property="createDate" column="create_date"/>
        <result property="updateDate" column="update_date"/>
    </resultMap>

    <select id="getUserById" parameterType="long" resultMap="UserMap">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" parameterType="string" resultMap="UserMap">
        SELECT id, email, password
        FROM users 
        WHERE email = #{email}
    </select>

    <insert id="joinUser" parameterType="com.jjy.contents_lab.dto.UserDto" useGeneratedKeys="true" keyProperty="id">
        INSERT users 
        SET email = #{email},
            password = #{password},
            user_name = #{userName},
            nickname = #{nickname},
            interest_content = #{interestContent},
            storage_limit = #{storageLimit},
            create_date = NOW()
    </insert>    

    <update id="updateUser" parameterType="com.jjy.contents_lab.dto.UserDto">
        UPDATE users
        <set>
            <if test="password != null">
                password = #{password},
            </if>
            <if test="userName != null">
                user_name = #{userName},
            </if>
            <if test="nickname != null">
                nickname = #{nickname},
            </if>
            <if test="interestContent != null">
                interest_content = #{interestContent},
            </if>
            update_date = NOW()
        </set>
        WHERE id = #{id}  
    </update>

    <update id="updatePassword">
        UPDATE users
        SET password = #{newPassword},
            update_date = NOW()
        WHERE id = #{userId}
    </update>
</mapper>